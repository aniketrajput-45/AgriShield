# ==========================================
# 1. SECRETS & ENVIRONMENT VARIABLES (CRITICAL)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
backend/.env

# ==========================================
# 2. PYTHON BACKEND (Virtual Envs & Caches)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.python-version

# ==========================================
# 3. FRONTEND / NODE (React / React Native)
# ==========================================
node_modules/
/dist
/build
.expo/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 4. LARGE ML FILES & DATASETS (Optional but smart)
# ==========================================
# Keeps massive raw datasets or heavy backup models off GitHub
*.h5
*.tar.gz
*.zip
/dataset/
/datasets/

# ==========================================
# 5. OPERATING SYSTEM FILES
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
.Desktop.ini